<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd"
             version="3.0">
    <persistence-unit name="orm_example">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>org.azamov.learnjakarta.task7_1.model.Student</class>
        <class>org.azamov.learnjakarta.task7_1.model.User</class>
        <class>org.azamov.learnjakarta.task7_1.model.Group</class>
        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/jakarta?currentSchema=jdbc_example"/>
            <property name="jakarta.persistence.jdbc.password" value="2255"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
        </properties>
    </persistence-unit>
</persistence>
